# MAIA EMG-ASL Server -- Railway Environment Variables
# Set these in the Railway dashboard or with: railway variables set KEY=VALUE

# ============================================================
# REQUIRED
# ============================================================

# API Authentication
# Set MAIA_DISABLE_AUTH=0 for production (auth required)
# Set MAIA_DISABLE_AUTH=1 for development/testing only
MAIA_DISABLE_AUTH=0

# Comma-separated list of valid API keys
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MAIA_API_KEYS=your-api-key-here

# ============================================================
# MODEL SOURCE (set one of these)
# ============================================================

# Option A: Download from Cloudflare R2 on startup (recommended for production)
# Set this after uploading your model with: python scripts/upload_artifact.py
R2_MODEL_URL=https://pub-xxxxxxxxxxxx.r2.dev/models/asl_emg_classifier.onnx

# Option B: Model bundled in the Docker image (simpler but requires redeploy for model updates)
ONNX_MODEL_PATH=models/asl_emg_classifier.onnx

# ============================================================
# OPTIONAL
# ============================================================

# Weights & Biases (for training runs, not needed for inference server)
WANDB_API_KEY=

# Log level
LOG_LEVEL=INFO
