# EMG-ASL Inference Server Environment Variables
# Copy this file to .env and fill in values

# API Authentication
# Set to "1" to disable auth (local development only -- never in production)
MAIA_DISABLE_AUTH=1

# Comma-separated list of valid API keys (leave blank to use dev-key-change-me)
MAIA_API_KEYS=

# Model paths
MODEL_PATH=models/asl_emg_classifier.onnx

# Server settings
HOST=0.0.0.0
PORT=8000
WS_PORT=8765
