# =============================================================================
# EMG-ASL Mobile App — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. It is listed in .gitignore.
# The .env.example file (with placeholder values) is safe to commit.
#
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible
# in Expo client-side code via process.env.EXPO_PUBLIC_<NAME>.
# =============================================================================

# WebSocket URL for the EMG-ASL inference server (streaming endpoint)
# Replace 192.168.1.x with your server machine's actual LAN IP address.
# Your phone and server must be on the same WiFi network.
#
# To find your server's LAN IP:
#   macOS:   ipconfig getifaddr en0
#   Linux:   hostname -I | awk '{print $1}'
#   Windows: ipconfig (look for IPv4 Address under WiFi adapter)
EXPO_PUBLIC_SERVER_URL=ws://192.168.1.x:8765

# REST API URL for calibration and health endpoints
EXPO_PUBLIC_REST_URL=http://192.168.1.x:8000

# BLE device name to scan for during pairing.
# The MYO Armband advertises as "Myo" (prefix match — may appear as "Myo (XXXX)").
# This must match the deviceName passed to bleManager.scanAndConnect() in BLEManager.ts.
EXPO_PUBLIC_BLE_DEVICE_NAME=Myo
